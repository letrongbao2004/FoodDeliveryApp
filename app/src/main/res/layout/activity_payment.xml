<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F8F8F8">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MoMo Payment"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:textAlignment="center"
        android:layout_marginBottom="24dp"/>

    <!-- Amount card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total amount"
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:id="@+id/tvPaymentAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 đ"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#A50064"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Recipient info card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transfer to MoMo account:"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:id="@+id/tvMomoPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0378 676 412"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap the button below to open MoMo"
                android:textSize="13sp"
                android:textColor="#888888"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Status -->
    <TextView
        android:id="@+id/tvPaymentStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Connecting to MoMo..."
        android:textSize="14sp"
        android:textColor="#555555"
        android:textAlignment="center"
        android:layout_marginBottom="8dp"/>

    <ProgressBar
        android:id="@+id/progressPayment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="visible"
        android:layout_marginBottom="16dp"/>

    <!-- QR Code card -->
    <androidx.cardview.widget.CardView
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">
        <ImageView
            android:id="@+id/ivPaymentQr"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:padding="12dp"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scan with phone camera or MoMo app"
        android:textSize="12sp"
        android:textColor="#888888"
        android:textAlignment="center"
        android:layout_marginBottom="20dp"/>

    <!-- Pay button -->
    <Button
        android:id="@+id/btnPayWithMoMo"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Open MoMo to Pay"
        android:backgroundTint="#A50064"
        android:textColor="@android:color/white"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

</LinearLayout>
